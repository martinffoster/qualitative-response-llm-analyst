# Copy to .env and fill in your OpenRouter credentials.
# Get an API key at https://openrouter.ai/

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional defaults (used by future multi-model orchestration)
MODEL_DEFAULTS=openai/gpt-4o,anthropic/claude-3.5-sonnet,google/gemini-2.0-flash
MAX_THEMES_PER_RESPONSE=5
TEMPERATURE_DEFAULT=0.2
LOG_LEVEL=INFO
